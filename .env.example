# =========================================================================
# PricePilot AI - Production Environment Variables Template
# Copy this file to .env and configure before executing docker-compose
# =========================================================================

# Database Connection (MongoDB Atlas URI recommended for production)
MONGODB_URI=mongodb://localhost:27017/pricepilot

# JWT Access and Refresh secrets (Generate strong random keys for production)
JWT_SECRET=super_secret_pricepilot_access_key_2026
JWT_REFRESH_SECRET=super_secret_pricepilot_refresh_key_2026

# Production API URL (The client-accessible URL of the backend API)
VITE_API_URL=http://localhost:8000/api

# Email Server Settings (For OTP forgot password system)
# Set these variables to enable sending real OTP emails via SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
